{
  "name": "@flowscale/aios-desktop",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "description": "FlowScale AIOS desktop application",
  "author": {
    "name": "FlowScale",
    "email": "hello@flowscale.ai"
  },
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['dist','release'].forEach(d=>{if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true})}})\"",
    "dev": "electron dist/main.js",
    "build": "tsc",
    "package": "electron-builder --config electron-builder.yml --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.3"
  }
}
