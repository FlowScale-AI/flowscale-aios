{
  "name": "@flowscale/aios-desktop",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "description": "FlowScale AIOS desktop application",
  "author": {
    "name": "FlowScale",
    "email": "hello@flowscale.ai"
  },
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron dist/main.js",
    "build": "tsc",
    "package": "electron-builder --config electron-builder.yml --publish never",
    "package:mac": "electron-builder --config electron-builder.yml --mac --publish never",
    "package:linux": "electron-builder --config electron-builder.yml --linux --publish never",
    "package:win": "electron-builder --config electron-builder.yml --win --publish never",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "electron-log": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.15.17",
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  }
}
